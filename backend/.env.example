# SQLite (default, zero config) — file lives in backend/prisma/dev.db
DATABASE_URL="file:./dev.db"

# For Postgres in production, comment the line above and use e.g.:
# DATABASE_URL="postgresql://user:password@localhost:5432/timetable_db"

# Secret used to sign JWTs — change this to a long random string in production
JWT_SECRET="replace-this-with-a-long-random-secret"

# Token lifetime
JWT_EXPIRES_IN="7d"

PORT=4000

# Comma-separated list of allowed frontend origins
CORS_ORIGIN="http://localhost:5173"

# Bootstrap super-admin account created automatically on first boot if it
# doesn't already exist. Change the password immediately after first login.
SUPER_ADMIN_EMAIL="admin@timetable.app"
SUPER_ADMIN_PASSWORD="ChangeMe123!"

# --- Stripe (Request Access -> paid signup flow) ---
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
# Signing secret for the webhook endpoint you create at
# https://dashboard.stripe.com/webhooks pointing to
# POST {your-api-url}/api/stripe/webhook, listening for:
#   checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_..."
# The Price ID of the plan schools subscribe to (create a Product +
# recurring Price in the Stripe Dashboard first)
STRIPE_PRICE_ID="price_..."
# Base URL of the deployed frontend, used to build Stripe redirect URLs
APP_URL="http://localhost:5173"
